ENV=local
DEBUG=true
APP_NAME=Dynamic Life Navigator
APP_VERSION=0.1.0
API_PREFIX=/api/v1
LOG_LEVEL=INFO
DEFAULT_USER_ID=local-user
ENABLE_WORKER_DISPATCH=false
PARSER_PROVIDER=deterministic
PARSER_SHADOW_ENABLED=true
PARSER_SHADOW_PROVIDER=gemini_direct
PROFILE_PROVIDER=deterministic
PROFILE_SHADOW_ENABLED=true
PROFILE_SHADOW_PROVIDER=gemini_direct
STRUCTURED_PARSER_VALIDATION_RETRIES=1
STRUCTURED_PARSER_MODEL_NAME=unconfigured-structured-parser
STRUCTURED_PARSER_TIMEOUT_SECONDS=30
STRUCTURED_PROFILE_MODEL_NAME=unconfigured-structured-profile
STRUCTURED_PROFILE_TIMEOUT_SECONDS=30
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/dln
REDIS_URL=redis://localhost:6379/0
WEBHOOK_IDEMPOTENCY_TTL_SECONDS=86400
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
